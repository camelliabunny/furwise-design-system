      "body-sm": {
        "fontFamily": "Inter, Gen Jyuu Gothic, 源柔ゴシック",
        "fontWeight": 500,
        "fontWeightName": "Medium",
        "fontSize": 12,
        "letterSpacing": 0.24,
        "usage": "Labels, card titles (貓咪名字, 每月體重紀錄)"
