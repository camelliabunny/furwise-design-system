      },
      "body": {
        "fontFamily": "Inter, Gen Jyuu Gothic, 源柔ゴシック",
        "fontWeight": 500,
        "fontWeightName": "Medium",
        "fontSize": 14,
        "letterSpacing": 0.28,
        "usage": "Buttons, emphasized body text (下一步, 調整內容與順序)"
