  "typography": {
    "fontFamilies": {
      "latin": "Inter",
      "cjk": "Gen Jyuu Gothic, 源柔ゴシック",
      "fallbackStack": "'Inter', 'Gen Jyuu Gothic', '源柔ゴシック', 'Noto Sans JP', 'Noto Sans TC', -apple-system, sans-serif",
      "_note": "English/numbers use Inter. Chinese/Japanese text uses 源柔ゴシック (Gen Jyuu Gothic). Noto Sans JP/SC as fallback for missing CJK glyphs."
    },

    "fontWeights": {
      "regular": 400,
      "medium": 500,
      "semiBold": 600,
      "bold": 700
    },

    "_colorNote": "Text color is intentionally excluded from type tokens. Use colors.text.primary (#3C2E21), colors.text.secondary (#7C6E6A), colors.primary.default (#FF8000), or colors.text.onDark (#FFFFFF) based on context.",

    "typeScale": {
      "title": {
        "fontFamily": "Inter, Gen Jyuu Gothic, 源柔ゴシック",
        "fontWeight": 700,
        "fontWeightName": "Bold",
        "fontSize": 24,
        "letterSpacing": 0.48,
        "usage": "Page titles (登錄貓咪資訊, etc.)"
      },
      "heading": {
        "fontFamily": "Inter, Gen Jyuu Gothic, 源柔ゴシック",
        "fontWeight": 600,
        "fontWeightName": "SemiBold",
        "fontSize": 16,
        "letterSpacing": 0.32,
        "usage": "Section headers (喵喵喵的紀錄, etc.)"
      },
      "subtitle": {
