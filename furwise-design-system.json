        "value": "#FFFAF5",
        "ref": "colors.primary.warm"
      },
      "gray": "#F9F9F9",
      "success": "#E8F5E9"
    },

    "border": {
      "strong": {
        "value": "#D0D0D0",
        "description": "Buttons, unselected chips"
      },
      "default": {
        "value": "#E0DDDA",
        "description": "Input fields, info tags"
      },
      "subtle": {
        "value": "#EEEEEE",
        "description": "Cards, record buttons"
      },
      "active": "#FF8000"
    },

    "decorative": {
      "gradientOrange": {
        "description": "Warm orange/peach gradient blobs used as decorative background elements"
      },
      "progressBarFill": {
        "value": "#FF8000",
        "ref": "colors.primary.default"
