      "body-xs": {
        "fontFamily": "Inter, Gen Jyuu Gothic, 源柔ゴシック",
        "fontWeight": 400,
        "fontWeightName": "Regular",
        "fontSize": 12,
        "letterSpacing": 0.24,
        "usage": "Body text, links, descriptions (晶片號碼, 立刻紀錄)"
      },
      "caption": {
        "fontFamily": "Inter, Gen Jyuu Gothic, 源柔ゴシック",
        "fontWeight": 400,
