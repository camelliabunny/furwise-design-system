      "sm": "Progress bars",
      "md": "Suggestion cards, time slot cards, calendar selected day",
      "lg": "Main cards, bottom sheet modals, add-new buttons",
      "xl": "Info tags",
      "full": "Buttons, inputs, selection chips",
      "tabBar": "Top corners only on tab bar"
